    "m_SourceType": 1,
    "m_FunctionName": "ExtendBorder",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "OUT.x = IN.x + (IN.x >= 0 ? OFF : -OFF);\nOUT.y = IN.y + (IN.y >= 0 ? OFF : -OFF);\nOUT.z = IN.z + (IN.z >= 0 ? OFF : -OFF);"
}

